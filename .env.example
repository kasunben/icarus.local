# icarus.local environment configuration
# Copy to .env and fill in values. Never commit .env.
# Generate secrets with: openssl rand -hex 24  (or hex 32 where noted)

# ---------------------------------------------------------------------------
# General
# ---------------------------------------------------------------------------
TZ=UTC
# Absolute path to your code directory, mounted into coding-sandbox at /workspace
CODING_WORKSPACE=~/Dev

# ---------------------------------------------------------------------------
# Postgres
# ---------------------------------------------------------------------------
# openssl rand -hex 24
POSTGRES_PASSWORD=

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
# openssl rand -hex 24
REDIS_PASSWORD=

# ---------------------------------------------------------------------------
# n8n
# ---------------------------------------------------------------------------
# make keygen
N8N_ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# Nextcloud
# ---------------------------------------------------------------------------
# Pin to a specific major version. Upgrade one version at a time — never :latest.
NEXTCLOUD_IMAGE=nextcloud:30-apache
# openssl rand -hex 24
NEXTCLOUD_DB_ROOT_PASSWORD=
# openssl rand -hex 24
NEXTCLOUD_DB_PASSWORD=
NEXTCLOUD_PHP_MEMORY_LIMIT=1024M
NEXTCLOUD_PHP_UPLOAD_LIMIT=10G
# Space-separated trusted domains (add LAN IP if using cross-device access)
NEXTCLOUD_TRUSTED_DOMAINS=localhost

# ---------------------------------------------------------------------------
# SearXNG
# ---------------------------------------------------------------------------
# openssl rand -hex 32
SEARXNG_SECRET_KEY=

# ---------------------------------------------------------------------------
# Garage (S3-compatible object storage)
# ---------------------------------------------------------------------------
# openssl rand -hex 32
GARAGE_RPC_SECRET=
# openssl rand -hex 32
GARAGE_ADMIN_TOKEN=
# Generated post-start via: docker exec icarus-garage /garage key info icarus-key
GARAGE_ACCESS_KEY=
GARAGE_SECRET_KEY=

# ---------------------------------------------------------------------------
# Open WebUI
# ---------------------------------------------------------------------------
# openssl rand -hex 32
OPEN_WEBUI_SECRET_KEY=

# ---------------------------------------------------------------------------
# OpenHands
# ---------------------------------------------------------------------------
# No secrets needed at compose level — configure LLM backend in the UI.
# OpenHands connects to Ollama on host via host.docker.internal:11434.

# ---------------------------------------------------------------------------
# Pi-hole
# ---------------------------------------------------------------------------
PIHOLE_WEBPASSWORD=
# Override if port 53 conflicts with mDNSResponder: check with `lsof -i :53`
# PIHOLE_DNS_PORT=5353

# ---------------------------------------------------------------------------
# Coding Sandbox
# ---------------------------------------------------------------------------
# Claude auth is stored in the icarus-coding-sandbox-claude named volume.
# On first use: make shell SERVICE=coding-sandbox  →  claude login
# Uses a separate Claude account — isolated from the host.
